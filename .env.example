# =============================================================================
# CONFIGURAÇÕES JL CAPITAL TRADE
# =============================================================================

# CREDENCIAIS METATRADER 5
MT5_LOGIN=1234567
MT5_PASSWORD=sua_senha_aqui
MT5_SERVER=MetaQuotes-Demo

# CONFIGURAÇÕES DE TRADING  
RISK_PER_TRADE=0.02
MAX_TRADES=5
STOP_LOSS_PIPS=50
TAKE_PROFIT_PIPS=100

# CONFIGURAÇÕES DE MODELOS DE ML
ACTIVE_MODELS=xgboost,lstm,ensemble
MODEL_UPDATE_FREQUENCY=24h

# CONFIGURAÇÕES DE LOG
LOG_LEVEL=INFO
LOG_FILE=jl_capital_trade.log

# CHAVE DE CRIPTOGRAFIA (gerar uma chave segura)
ENCRYPTION_KEY=sua_chave_secreta_aqui_32_bytes

# CONFIGURAÇÕES DE API (opcional)
API_HOST=localhost
API_PORT=8000
API_KEY=sua_chave_api_aqui